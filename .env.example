# =====================================================
# 便宜機票搜尋器 - 環境變數範例
# =====================================================
# 複製此檔案為 .env 並填入您的實際設定
# cp .env.example .env
# =====================================================

# -----------------------------------------------------
# Telegram Bot 設定
# -----------------------------------------------------
# 從 @BotFather 獲取的 Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 您的 Telegram Chat ID (用於接收通知)
# 可透過發送訊息給 @userinfobot 獲取
TELEGRAM_CHAT_ID=your_chat_id_here

# -----------------------------------------------------
# 機票 API 設定 (選擇其一)
# -----------------------------------------------------
# Skyscanner API (免費，需申請)
# 申請網址: https://partners.skyscanner.net/
SKYSCANNER_API_KEY=your_skyscanner_api_key_here

# SerpApi (付費，Google Flights 資料)
# 申請網址: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_key_here

# Amadeus API (免費額度)
# 申請網址: https://developers.amadeus.com/
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# -----------------------------------------------------
# 使用者偏好設定
# -----------------------------------------------------
# 您的所在地區 (用於計算交通費用)
# 可選值: 台北市, 新北市, 桃園, 新竹, 台中, 台南, 高雄
USER_LOCATION=台北市

# 偏好的出發機場 (IATA 代碼，逗號分隔)
# TPE: 桃園國際機場
# TSA: 台北松山機場
# KHH: 高雄國際機場
PREFERRED_AIRPORTS=TPE,TSA

# 關注的目的地 (IATA 代碼，逗號分隔)
# 常見: NRT/HND(東京), KIX(大阪), ICN(首爾), BKK(曼谷), SIN(新加坡)
WATCH_DESTINATIONS=NRT,HND,KIX,ICN

# -----------------------------------------------------
# 搜尋設定
# -----------------------------------------------------
# 搜尋的行程天數 (逗號分隔)
TRIP_DURATIONS=3,4,5,7

# 提前搜尋天數 (從今天算起)
SEARCH_DAYS_AHEAD=60

# 價格警報閾值 (低於此價格才通知，單位: TWD)
PRICE_ALERT_THRESHOLD=8000

# -----------------------------------------------------
# 排程設定
# -----------------------------------------------------
# 搜尋頻率 (cron 格式)
# 預設: 每天早上 8 點和晚上 8 點
SEARCH_CRON="0 8,20 * * *"

# -----------------------------------------------------
# Web UI 設定
# -----------------------------------------------------
# Web UI 運行埠號
WEB_PORT=3000

# -----------------------------------------------------
# 資料庫設定
# -----------------------------------------------------
# SQLite 資料庫路徑 (相對於專案根目錄)
DATABASE_URL="file:./prisma/fly.db"
